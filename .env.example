# Copy to .env and edit. Lines starting with `#` are ignored.

# Optional second output directory — typically a Syncthing folder that mirrors
# built .apkg files to your phone. Leave unset (or comment out) to skip the
# extra copy; generate.py will still write to ./output-decks/.
# Supports a leading `~` for your home directory.
# SYNC_DIR=~/Documents/syncthing/phone/anki-decks
